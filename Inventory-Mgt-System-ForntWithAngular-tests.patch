 import { TestBed } from '@angular/core/testing';
+import { HttpTestingController, provideHttpClientTesting } from '@angular/common/http/testing';
+import { provideHttpClient } from '@angular/common/http';
 
 import { ApiService } from './api.service';
 
+/**
+ * Regression tests for ApiService.
+ *
+ * Two real bugs are covered here:
+ *  - updateProduct() built its URL with single quotes instead of a
+ *    template literal, so `${ApiService.BASE_URL}/products/update` was
+ *    sent to the server literally instead of being interpolated — editing
+ *    a product from the UI never actually reached the backend.
+ *  - getAlltransactions() sent a `searchText` query param, but the
+ *    backend's /transactions/all endpoint only reads `searchBox`, so the
+ *    transaction search filter silently did nothing.
+ */
 describe('ApiService', () => {
   let service: ApiService;
+  let httpMock: HttpTestingController;
 
   beforeEach(() => {
-    TestBed.configureTestingModule({});
+    TestBed.configureTestingModule({
+      providers: [provideHttpClient(), provideHttpClientTesting()]
+    });
     service = TestBed.inject(ApiService);
+    httpMock = TestBed.inject(HttpTestingController);
+  });
+
+  afterEach(() => {
+    httpMock.verify();
   });
 
   it('should be created', () => {
     expect(service).toBeTruthy();
   });
+
+  it('updateProduct sends a PUT to the real, interpolated backend URL', () => {
+    const formData = new FormData();
+
+    service.updateProduct(formData).subscribe();
+
+    const req = httpMock.expectOne(
+      (r) => r.method === 'PUT' && r.url === 'http://localhost:8080/api/products/update'
+    );
+    expect(req.request.url).not.toContain('${ApiService.BASE_URL}');
+    req.flush({ status: 200 });
+  });
+
+  it('getAlltransactions sends the search text as "searchBox", matching the backend param name', () => {
+    service.getAlltransactions('laptop').subscribe();
+
+    const req = httpMock.expectOne(
+      (r) => r.method === 'GET' && r.url === 'http://localhost:8080/api/transactions/all'
+    );
+    expect(req.request.params.get('searchBox')).toBe('laptop');
+    expect(req.request.params.has('searchText')).toBeFalse();
+    req.flush({ status: 200 });
+  });
 });
